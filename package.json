{
  "name": "NovaPad",
  "version": "1.1.0",
  "description": "A lightweight, fast, and modern text editor for Windows, macOS.",
  "main": "out/main/index.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "node scripts/build-worker.mjs && env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "build": "electron-vite build && node scripts/build-worker.mjs",
    "preview": "env -u ELECTRON_RUN_AS_NODE electron-vite preview",
    "package": "[ -f .env ] && set -a && . ./.env && set +a; electron-builder",
    "package:win": "[ -f .env ] && set -a && . ./.env && set +a; electron-builder --win",
    "package:mac": "[ -f .env ] && set -a && . ./.env && set +a; electron-builder --mac",
    "release:preflight": "[ -f .env ] && set -a && . ./.env && set +a; node scripts/release-preflight.mjs",
    "release:mac": "[ -f .env ] && set -a && . ./.env && set +a; npm run release:preflight -- mac && npm run build && GH_TOKEN=$(gh auth token) electron-builder --mac --publish always",
    "release:win": "[ -f .env ] && set -a && . ./.env && set +a; npm run release:preflight -- win && npm run build && GH_TOKEN=$(gh auth token) electron-builder --win --publish always",
    "release:verify": "[ -f .env ] && set -a && . ./.env && set +a; node scripts/verify-release.mjs",
    "release:all": "[ -f .env ] && set -a && . ./.env && set +a; npm run release:preflight -- all && npm run release:mac && npm run release:win && npm run release:verify",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:headed": "npm run build && playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "build:worker": "node scripts/build-worker.mjs",
    "postinstall": "node node_modules/electron/install.js"
  },
  "dependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.0.20",
    "@hookform/resolvers": "^3.10.0",
    "@monaco-editor/react": "^4.6.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-virtual": "^3.13.23",
    "chardet": "^2.0.0",
    "chokidar": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "electron-updater": "^6.8.3",
    "embla-carousel-react": "^8.6.0",
    "fast-xml-parser": "^4.5.1",
    "iconv-lite": "^0.6.3",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.7.0",
    "monaco-editor": "^0.52.2",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.72.1",
    "react-resizable-panels": "^2.1.7",
    "recharts": "^2.15.4",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.1",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^0.9.9",
    "zod": "^3.25.76",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.27",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
