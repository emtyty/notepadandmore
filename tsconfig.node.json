{
  "compilerOptions": {
    "composite": true,
    "module": "CommonJS",
    "target": "ES2020",
    "lib": ["ES2020"],
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "out",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": [
    "electron-vite.config.*",
    "src/main/**/*",
    "src/preload/**/*"
  ]
}
